{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sync-latest.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/checkpoint-push.sh",
            "statusMessage": "Checkpointing + pushing work…"
          }
        ]
      }
    ]
  }
}
