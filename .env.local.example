# LIQWD — local environment
# Copy this file to ".env.local" and fill in real values from the Supabase dashboard
# (Project Settings -> API). NEVER commit real keys.

# Public (safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. MUST NOT be exposed to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — OPTIONAL. Powers the PAID Ultra path. When unset, the Ultra page
# falls back to a contact CTA and admins can still grant Ultra by hand.
# Server-only secrets — never expose to the client.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_ULTRA_PRICE_ID=price_...           # recurring Price for Ultra
STRIPE_WEBHOOK_SECRET=whsec_...           # from `stripe listen` or the dashboard
# STRIPE_ULTRA_PRICE_LABEL=$49 / mo       # optional display string on the Ultra page

# Optional: absolute site URL used for Stripe redirect URLs (falls back to the
# request host). e.g. https://app.liqwd.ca
# NEXT_PUBLIC_SITE_URL=
