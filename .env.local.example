# LIQWD — local environment
# Copy this file to ".env.local" and fill in real values from the Supabase dashboard
# (Project Settings -> API). NEVER commit real keys.

# Public (safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. MUST NOT be exposed to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
