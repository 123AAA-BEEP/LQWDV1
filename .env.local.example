# LIQWD — local environment
# Copy this file to ".env.local" and fill in real values from the Supabase dashboard
# (Project Settings -> API). NEVER commit real keys.

# Public (safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. MUST NOT be exposed to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Image sourcing (Admin -> Images). Server-only.
# GOOGLE_CSE_KEY: Google Cloud API key with the "Custom Search API" enabled.
# GOOGLE_CSE_CX:  a Programmable Search Engine ID (https://programmablesearchengine.google.com)
#   created with "Search the entire web" + Image search turned on.
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# Optional: shared secret to protect the /api/cron/source-images endpoint.
# Set the same value in a Vercel Cron job's Authorization: Bearer <secret> header.
CRON_SECRET=
