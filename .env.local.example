# LIQWD — local environment
# Copy this file to ".env.local" and fill in real values from the Supabase dashboard
# (Project Settings -> API). NEVER commit real keys.

# Public (safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. MUST NOT be exposed to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — OPTIONAL. Powers the self-serve PRO tier. When unset, the upgrade
# page shows a "launching soon" state and nothing else is affected. Pro does
# NOT grant Ultra/Deal Desk (that stays invitation-only). Server-only secrets.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...             # recurring Price for realtor Pro ($9.99/mo)
STRIPE_ULTRA_PRICE_ID=price_...           # recurring Price for realtor Ultra ($19.99/mo)
STRIPE_WEBHOOK_SECRET=whsec_...           # from the /api/stripe/webhook endpoint
# STRIPE_PRO_PRICE_LABEL=$9.99 / mo       # optional display string on the plans page
# STRIPE_ULTRA_PRICE_LABEL=$19.99 / mo    # optional display string on the plans page

# Developer billing for the buyer-mandate marketplace (all optional).
# STRIPE_DEVELOPER_PRICE_ID=price_...           # recurring Price: developer subscription (unlimited connects)
# STRIPE_DEVELOPER_PRICE_LABEL=$199 / mo
# STRIPE_CONNECT_CREDITS_PRICE_ID=price_...     # one-time Price: a connect-credit pack
# STRIPE_CONNECT_CREDITS_PRICE_LABEL=$49 for 10 connects
# STRIPE_CONNECT_CREDITS_QTY=10                 # credits granted per pack (default 10)

# Optional: absolute site URL for Stripe redirect URLs (else derived from the
# request host). e.g. https://liqwd.ca
# NEXT_PUBLIC_SITE_URL=

# Transactional email (Resend) — OPTIONAL. When unset, sendEmail() is a no-op,
# so RECO expiry reminders / eBlasts simply don't send (nothing breaks). Set
# both to enable. See docs/auth-emails/README.md for the domain + DNS setup.
# RESEND_API_KEY=re_...
# EMAIL_FROM=LIQWD <no-reply@liqwd.ca>

